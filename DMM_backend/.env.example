# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== Database =====
MONGO_URI=mongodb://localhost:27017/dmm_platform

# ===== Auth =====
# Generate a long random string, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ===== Frontend (CORS + email links) =====
# Comma-separated list of allowed origins. First entry is used for email links.
# 5173 = main product (DMM_frontend), 5174 = admin portal (DMM_Admin)
CLIENT_URL=http://localhost:5173,http://localhost:5174

# ===== File Storage =====
# "local" stores uploads on disk; "cloudinary" uploads to Cloudinary.
STORAGE_DRIVER=local

# Disk location for locally-stored files (used when STORAGE_DRIVER=local).
# Leave empty to use the app's own ./uploads folder (good for local dev).
# In production point this at your mounted storage volume — e.g. TrueNAS:
#   LOCAL_STORAGE_ROOT=/mnt/tag-storage
# Everything (templates, assets, brand assets, approvals, avatars) is written
# under and served from this one path, so this single setting moves all storage.
LOCAL_STORAGE_ROOT=

# ===== Cloudinary (only if STORAGE_DRIVER=cloudinary) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Meta (Facebook + Instagram) analytics — optional =====
# Paste your Meta System User access token here to enable one-click "Sync from
# Meta" for Instagram & Facebook. The token stays on the server and is NEVER sent
# to the browser or committed to git. Generate it in Meta Business Settings ->
# System Users, with these scopes:
#   instagram_basic, instagram_manage_insights, pages_show_list,
#   pages_read_engagement, business_management
# Leave blank to keep using manual Excel import instead.
META_SYSTEM_TOKEN=
# App Secret — required ONLY if your Meta app has "Require app secret proof for
# server API calls" enabled (Meta app -> Settings -> Basic -> App Secret).
META_APP_SECRET=
# Graph API version (optional; defaults to v21.0)
META_API_VERSION=v21.0

# ===== YouTube analytics — optional =====
# A YouTube Data API v3 key (Google Cloud Console -> APIs & Services -> Credentials).
# Enables one-click "Sync from YouTube" for public channel stats (subscribers,
# views, video count, engagement). Server-side only; never sent to the browser.
YOUTUBE_API_KEY=

# ===== AI Assistant (Claude) — optional =====
# An Anthropic API key (https://console.anthropic.com -> API Keys) enables the
# built-in "Ask t@g" assistant that answers questions about your organizations'
# analytics, goals, approvals and plans using live data. Server-side only; the
# key is NEVER sent to the browser or committed to git.
ANTHROPIC_API_KEY=
# Optional model override (defaults to Claude Haiku 4.5 — fast and cheap).
# Use claude-sonnet-5 for higher-quality answers at a higher cost.
ANTHROPIC_MODEL=

# ===== Email / SMTP (optional) =====
# Required for self-service password reset and welcome emails.
# If left blank, password reset must be done by an admin from the admin panel.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DMM Platform <no-reply@yourdomain.com>
